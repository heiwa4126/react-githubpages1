{
	"name": "react-githubpages1",
	"private": true,
	"version": "1.0.19",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"format": "biome format --config-path=\"$HOME/biome.json\" --write . && dprint fmt  && textlint --fix \"**/*.md\"",
		"check": "biome check --write . && dprint check",
		"lint": "biome lint .",
		"actionlint": "actionlint .github/**/*.yml",
		"preview": "vite preview",
		"bp": "tsc && vite build && vite preview",
		"pinact": "pinact run"
	},
	"dependencies": {
		"react": "~19.2.0",
		"react-dom": "~19.2.0",
		"react-router": "~7.9.4"
	},
	"devDependencies": {
		"@types/node": "^24.9.1",
		"@types/react": "~19.2.2",
		"@types/react-dom": "~19.2.2",
		"@vitejs/plugin-react-swc": "^4.1.0",
		"typescript": "^5.9.3",
		"vite": "~7.1.11"
	}
}
